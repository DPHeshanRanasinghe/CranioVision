# ===== CranioVision .gitignore =====
#
# Dev branch policy:
# Keep the commit surface focused on core source and docs.
# Track: src/, README.md, .gitignore, and any intentional root metadata.
# Do not track local apps, notebooks, datasets, model artifacts, outputs, tests,
# machine-specific assistant files, or generated caches.

# Medical data / datasets
data/*
!data/demo.mp4
*.nii
*.nii.gz
*.dcm
*.dicom

# Model checkpoints and local model artifacts
models/
*.pth
*.pt
*.ckpt
*.onnx

# Outputs and experiment results
outputs/
logs/
wandb/
mlruns/
lightning_logs/

# Local application folders not intended for this branch
backend/
frontend/

# Notebooks and tests not intended for this branch
notebooks/
tests/
pytest.ini
.ipynb_checkpoints/
*.ipynb_checkpoints

# Project-local/private folders
atlas_data/
configs/
.claude/
CLAUDE.md
claude.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing / coverage caches
.pytest_cache/
.coverage
htmlcov/
.tox/

# Environment files with secrets
.env
.env.local
*.key
*.pem

# Temporary
tmp/
temp/
*.tmp
*.bak

