# ===== CranioVision .gitignore =====
#
# Public-facing repository policy:
#   Track the conceptual work and engineering artifacts that demonstrate
#   the project's design and capability.
#   Do not track datasets, trained weights, application code, runtime
#   outputs, or local development context.

# ---------------------------------------------------------------------------
# Medical data and datasets (proprietary / licensed via BraTS)
# ---------------------------------------------------------------------------
data/
*.nii
*.nii.gz
*.dcm
*.dicom

# ---------------------------------------------------------------------------
# Trained models and checkpoints
# ---------------------------------------------------------------------------
models/
*.pth
*.pt
*.ckpt
*.onnx
*.pb
*.h5
*.safetensors

# ---------------------------------------------------------------------------
# Pipeline outputs (reports, atlas registration cache, logs)
# ---------------------------------------------------------------------------
outputs/
logs/
wandb/
mlruns/
lightning_logs/
runs/
tb_logs/

# ---------------------------------------------------------------------------
# Application code (intentionally not part of the public showcase)
# ---------------------------------------------------------------------------
backend/
frontend/

# ---------------------------------------------------------------------------
# Notebooks (training + evaluation not exposed publicly)
# ---------------------------------------------------------------------------
notebooks/
*.ipynb
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------
tests/
pytest.ini

# ---------------------------------------------------------------------------
# Atlas templates (Harvard-Oxford and MNI; available via FSL directly)
# ---------------------------------------------------------------------------
atlas_data/

# ---------------------------------------------------------------------------
# Local development context, IDE files, AI assistant state
# ---------------------------------------------------------------------------
configs/
.claude/
CLAUDE.md
claude.md
DESIGN_BRIEF.md
.cursor/
.aider*
.continue/
.windsurf/

# ---------------------------------------------------------------------------
# Python build / cache artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.eggs/
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# IDE / editor metadata
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ---------------------------------------------------------------------------
# Operating system files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------------------------------------------------------------------------
# Test / coverage tools
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ---------------------------------------------------------------------------
# Environment files (secrets, API keys, machine-specific)
# ---------------------------------------------------------------------------
.env
.env.*
*.key
*.pem
secrets.json

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.log

# ---------------------------------------------------------------------------
# Node.js (in case any frontend artifacts leak through)
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
package-lock.json
yarn.lock
pnpm-lock.yaml
